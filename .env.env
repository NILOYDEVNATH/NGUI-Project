# Supabase Configuration
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Display Configuration
# Options: 'monitor', 'led', or 'both'
DISPLAY_TYPE=monitor

# Web Server Port (for monitor display)
DISPLAY_PORT=8080

# Update frequency (milliseconds)
TEXT_REFRESH_RATE=100

# LED Matrix Configuration (if using LED)
LED_ROWS=32
LED_COLS=64
LED_BRIGHTNESS=100
LED_GPIO_SLOWDOWN=2

# Logging
LOG_LEVEL=info
LOG_FILE=logs/display.log
